# ht-l1-core environment template. Copy to .env for local use.
# Do not commit .env or real secrets.

# Optional BrowserFetch service override. Defaults to local service URL.
HT_BROWSER_FETCH_URL=

# Optional bearer token sent to BrowserFetch when the service requires auth.
HT_BROWSER_FETCH_TOKEN=

# Optional 40-character commit SHA used when package metadata has no git checkout.
HT_CODE_SHA=

# Optional LLM spend guardrails. Leave blank for no cap.
LLM_DAILY_BUDGET_USD=
LLM_PER_CALL_BUDGET_USD=
